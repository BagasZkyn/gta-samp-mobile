<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/md_glass_bg_dark"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/md_glass_stroke_dark"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Server Name -->
        <TextView
            android:id="@+id/tv_server_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Server Name"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="@color/md_theme_dark_onSurface"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/img_favorite" />

        <!-- Favorite toggle -->
        <ImageButton
            android:id="@+id/img_favorite"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/btn_star_big_off"
            android:contentDescription="Favorite"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Gamemode + Map -->
        <TextView
            android:id="@+id/tv_gamemode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Roleplay • San Andreas"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="@color/md_theme_dark_onSurfaceVariant"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_server_name"
            app:layout_constraintEnd_toStartOf="@+id/img_favorite" />

        <!-- Address -->
        <TextView
            android:id="@+id/tv_address"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.0.0.0:7798"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="@color/md_theme_dark_onSurfaceVariant"
            android:alpha="0.6"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_gamemode" />

        <!-- Players chip -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_players"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/0"
            android:textSize="11sp"
            app:chipBackgroundColor="@color/md_theme_dark_secondaryContainer"
            app:chipCornerRadius="8dp"
            app:chipMinHeight="28dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="6dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_address" />

        <!-- Ping chip -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_ping"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="— ms"
            android:textSize="11sp"
            app:chipBackgroundColor="@color/md_theme_dark_surfaceVariant"
            app:chipCornerRadius="8dp"
            app:chipMinHeight="28dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="6dp"
            app:layout_constraintStart_toEndOf="@+id/chip_players"
            app:layout_constraintTop_toBottomOf="@+id/tv_address" />

        <!-- Lock icon if passworded -->
        <ImageView
            android:id="@+id/iv_lock"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_lock_idle_lock"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toEndOf="@+id/chip_ping"
            app:layout_constraintTop_toBottomOf="@+id/tv_address"
            app:layout_constraintBottom_toBottomOf="@+id/chip_ping" />

        <!-- Connect button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_connect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connect"
            android:textSize="12sp"
            app:backgroundTint="@color/md_theme_dark_primary"
            app:cornerRadius="16dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_address" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
