<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_dark_surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Hero Card ─────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_hero"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/md_theme_dark_primaryContainer"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="20dp">

                <!-- Server Logo / App Icon -->
                <ImageView
                    android:id="@+id/img_logo"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@mipmap/ic_launcher_round"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_server_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Djava Roleplay"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall"
                    android:textColor="@color/md_theme_dark_onPrimaryContainer"
                    android:fontFamily="sans-serif-medium"
                    app:layout_constraintStart_toEndOf="@+id/img_logo"
                    app:layout_constraintTop_toTopOf="@+id/img_logo"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tv_server_address"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="4dp"
                    android:text="151.240.0.201:7798"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="@color/md_theme_dark_onPrimaryContainer"
                    android:alpha="0.75"
                    app:layout_constraintStart_toEndOf="@+id/img_logo"
                    app:layout_constraintTop_toBottomOf="@+id/tv_server_name"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- File status chip -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_file_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_files_missing"
                    android:textSize="11sp"
                    app:chipBackgroundColor="@color/md_theme_dark_secondaryContainer"
                    app:chipCornerRadius="12dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintBottom_toTopOf="@+id/btn_launch" />

                <!-- Launch Game Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_launch_game"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:text="@string/dashboard_launch_game"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    app:backgroundTint="@color/md_theme_dark_primary"
                    app:cornerRadius="24dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />


            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Stats Row ──────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Players online -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/md_glass_bg_dark"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/md_glass_stroke_dark"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_player_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textAppearance="?attr/textAppearanceTitleLarge"
                        android:textColor="@color/md_theme_dark_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pemain"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="@color/md_theme_dark_onSurfaceVariant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Ping -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/md_glass_bg_dark"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/md_glass_stroke_dark"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_ping"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textAppearance="?attr/textAppearanceTitleLarge"
                        android:textColor="@color/md_theme_dark_secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ping (ms)"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="@color/md_theme_dark_onSurfaceVariant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Max Players -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="@color/md_glass_bg_dark"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/md_glass_stroke_dark"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_max_players"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textAppearance="?attr/textAppearanceTitleLarge"
                        android:textColor="@color/md_theme_dark_tertiary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Max Slot"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="@color/md_theme_dark_onSurfaceVariant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- ── Server Info Card ──────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_server"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/md_glass_bg_dark"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/md_glass_stroke_dark"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Server Utama"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="@color/md_theme_dark_onSurface"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_server_hostname"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Memuat…"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:textColor="@color/md_theme_dark_primary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_server_gamemode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Roleplay"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/md_theme_dark_onSurfaceVariant"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_connect_main"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_connect_now"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="@color/md_theme_dark_primary"
                    app:cornerRadius="20dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Download Status Card ──────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_download_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/md_glass_bg_dark"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/md_glass_stroke_dark"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cache Game Files"
                        android:textAppearance="?attr/textAppearanceTitleSmall"
                        android:textColor="@color/md_theme_dark_onSurface" />

                    <TextView
                        android:id="@+id/tv_file_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_files_missing"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/md_theme_dark_onSurfaceVariant"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_go_download"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_download_now"
                    android:textSize="12sp"
                    app:backgroundTint="@color/md_theme_dark_secondaryContainer"
                    app:cornerRadius="16dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── News / Info Card ───────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/md_glass_bg_dark"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/md_glass_stroke_dark"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Info"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="@color/md_theme_dark_onSurface"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Selamat datang di Djava Roleplay! Server kami menyediakan pengalaman bermain SA-MP terbaik dengan sistem roleplay yang mendalam.\n\n• Download game cache agar gameplay lancar\n• Hubungi admin jika ada masalah\n• Discord: discord.gg/djava"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/md_theme_dark_onSurfaceVariant"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
