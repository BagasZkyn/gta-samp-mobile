<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_dark_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textColor="@color/md_theme_dark_onSurface"
            android:layout_marginBottom="16dp" />

        <!-- ── Game Settings ─────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_game_group"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="@color/md_theme_dark_primary"
            android:layout_marginBottom="8dp"
            android:paddingStart="4dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/md_glass_bg_dark"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/md_glass_stroke_dark"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Default server IP -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_server_ip"
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textColor="@color/md_theme_dark_onSurface" />
                        <TextView
                            android:id="@+id/tv_server_ip_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="151.240.0.201:7798"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/md_theme_dark_onSurfaceVariant" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/md_glass_stroke_dark" android:layout_marginBottom="8dp" />

                <!-- Show FPS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_show_fps"
                        android:textAppearance="?attr/textAppearanceTitleSmall"
                        android:textColor="@color/md_theme_dark_onSurface" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_show_fps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/md_glass_stroke_dark" android:layout_marginBottom="8dp" />

                <!-- Vibration -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_vibration"
                        android:textAppearance="?attr/textAppearanceTitleSmall"
                        android:textColor="@color/md_theme_dark_onSurface" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_vibration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Audio Settings ────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_audio_group"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="@color/md_theme_dark_primary"
            android:layout_marginBottom="8dp"
            android:paddingStart="4dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/md_glass_bg_dark"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/md_glass_stroke_dark"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Audio enabled -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_audio_enabled"
                        android:textAppearance="?attr/textAppearanceTitleSmall"
                        android:textColor="@color/md_theme_dark_onSurface" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_audio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/md_glass_stroke_dark" android:layout_marginBottom="8dp" />

                <!-- Volume slider -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_audio_volume"
                    android:textAppearance="?attr/textAppearanceTitleSmall"
                    android:textColor="@color/md_theme_dark_onSurface"
                    android:layout_marginBottom="4dp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_volume"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:value="80"
                    android:valueFrom="0"
                    android:valueTo="100"
                    android:stepSize="5"
                    app:thumbColor="@color/md_theme_dark_primary"
                    app:trackColorActive="@color/md_theme_dark_primary"
                    app:trackColorInactive="@color/md_theme_dark_surfaceVariant" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── About ──────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_about_group"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="@color/md_theme_dark_primary"
            android:layout_marginBottom="8dp"
            android:paddingStart="4dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/md_glass_bg_dark"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/md_glass_stroke_dark"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_version"
                        android:textAppearance="?attr/textAppearanceTitleSmall"
                        android:textColor="@color/md_theme_dark_onSurface" />

                    <TextView
                        android:id="@+id/tv_app_version"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="v2.10"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/md_theme_dark_onSurfaceVariant" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/md_glass_stroke_dark" android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_discord"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_discord"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="@color/md_theme_dark_primary"
                    app:cornerRadius="12dp"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear_cache"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_clear_cache"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="@color/md_theme_dark_error"
                    android:textColor="@color/md_theme_dark_error"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
